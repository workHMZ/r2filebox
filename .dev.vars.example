# Copy to .dev.vars for local development.
# Do not commit .dev.vars.

# ADMIN_USERNAME defaults to admin. Unicode names and email-style usernames are supported.
ADMIN_USERNAME=admin

# Choose one login method. ADMIN_PASSWORD must contain 16-4096 characters.
# Advanced: leave ADMIN_PASSWORD unset and use an interactive `npm run hash-password`
# result as ADMIN_PASSWORD_HASH. The hash takes precedence when both are set.
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Generate each value once with `openssl rand -hex 32` and keep it stable.
# Rotating CODE_HASH_PEPPER breaks validation of existing extraction codes.
CODE_HASH_PEPPER=
# Rotating SESSION_SECRET invalidates admin sessions and short-lived download tokens.
SESSION_SECRET=
